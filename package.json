{
  "name": "dictum",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "generate:api": "pnpm generate:api:frontend && ./services/api/mvnw -f services/api/pom.xml generate-sources",
    "generate:api:frontend": "rm -rf packages/api-client/src/generated && pnpm exec openapi-generator-cli generate -i docs/openapi/dictum.yaml -g typescript-fetch -o packages/api-client/src/generated --additional-properties=typescriptThreePlus=true,supportsES6=true,useSingleRequestParameter=true,modelPropertyNaming=original",
    "dev:admin": "pnpm --dir apps/admin dev",
    "dev:api": "./services/api/mvnw -f services/api/pom.xml spring-boot:run",
    "build:web": "pnpm --filter @dictum/admin build",
    "verify:api": "./services/api/mvnw -f services/api/pom.xml verify",
    "test:api": "./services/api/mvnw -f services/api/pom.xml test",
    "lint:api": "./services/api/mvnw -f services/api/pom.xml validate spotless:check",
    "format:api": "./services/api/mvnw -f services/api/pom.xml spotless:apply",
    "lint:web": "pnpm exec biome check apps packages",
    "format:web": "pnpm exec biome format --write apps packages",
    "typecheck:web": "pnpm --filter @dictum/admin typecheck",
    "sonar:start": "docker compose up -d",
    "sonar:stop": "docker compose down",
    "sonar:scan": "pnpm exec sonar",
    "sonar:ide": "node scripts/quality/analyze-with-sonarqube-ide.mjs",
    "sonar:validate": "node scripts/quality/validate-with-sonar.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@openapitools/openapi-generator-cli": "2.30.2",
    "@sonar/scan": "4.3.0"
  }
}
